     <property name="styleSheet">
      <string notr="true">#scrollArea{border:none}

QWidget{font-family:&quot;微软雅黑&quot;;outline:0px;}

QPushButton,QLineEdit,QComboBox{min-height:30px}

QWidget{font-size:21px;background-color: #e9f3f9;}


QLineEdit,QComboBox{padding-left:9px}

/* 下拉后，整个下拉窗体每项的样式 */
QComboBox QAbstractItemView::item {
    height: 40px;
	padding-left:9px;
}

/*QComboBox样式 START========================================================================*/
QComboBox{background:transparent;padding-left:9px;border:1px solid #18679d1;border-radius:4px;;border:1px solid rgb(40,160,252);}
QLineEdit{background:transparent;padding-left:9px;border:1px solid #18679d1;border-radius:4px;border:1px solid rgb(40,160,252);}
QTextEdit{background:transparent;padding-left:9px;border:1px solid #18679d1;border-radius:4px;border:1px solid rgb(40,160,252);}
QComboBox::drop-down{border:none} 
QComboBox::down-arrow{padding-right:25px; min-width:50px;min-height:30px;image: url(:/image/mainwindow/xiangxiajiantou.png);}
QComboBox::down-arrow:on{padding-right:25px; min-width:50px;min-height:30px; image: url(:/image/mainwindow/xiangshangjiantou.png);}

/*QComboBox QFrame{background-color:#4be26e;border:none;}*/
QComboBox QAbstractItemView {color:white;background-color:rgb(153, 180, 197);outline:0px;border:none;padding-left:0px;/*边距（还有其他方向边距设置方式）*/} 

/* 下拉后，整个下拉窗体每项的样式 */
QComboBox QAbstractItemView::item {
    height: 40px;   /* 项的高度（设置pComboBox-&gt;setView(new QListView());后，该项才起作用） */
	color: #FFFFFF;
	padding-left:0px;
}
 
/* 下拉后，整个下拉窗体越过每项的样式 */
QComboBox QAbstractItemView::item:hover,QComboBox QAbstractItemView::item:selected {
    height: 40px;   /* 项的高度（设置pComboBox-&gt;setView(new QListView());后，该项才起作用） */
	color: #FFFFFF;
	padding-left:0px;
    background-color: rgb(40,160,252);   /* 整个下拉窗体越过每项的背景色 */
}

QComboBox:hover{border:1px solid rgb(34,177,253);border-radius:4px}
QLineEdit:hover{border:1px solid rgb(34,177,253);border-radius:4px}
QTextEdit:hover{border:1px solid rgb(34,177,253);border-radius:4px}</string>
